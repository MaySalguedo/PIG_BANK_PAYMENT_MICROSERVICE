{
  "name": "pig_bank_payment_microservice",
  "version": "1.0.0",
  "description": "PIG BANK – Payment & Catalog microservice (Part 2)",
  "main": "dist/handler.js",
  "type": "commonjs",
  "scripts": {
    "clean": "rm -rf dist",
    "bundle": "esbuild src/infra/handlers/*.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist --external:@aws-sdk/*",
    "build": "tar -a -c -f lambda.zip dist package.json",
    "compile": "run-s clean bundle build",
    "tf:init": "terraform init",
    "tf:apply": "terraform apply -auto-approve -replace=\"aws_api_gateway_deployment.payment_deployment\"",
    "deploy:init": "run-s compile tf:init tf:apply",
    "deploy": "run-s compile tf:apply"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1003.0",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/client-sqs": "^3.1003.0",
    "@aws-sdk/lib-dynamodb": "^3.1003.0",
    "csv-parse": "^5.6.0",
    "ioredis": "^5.4.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.5",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
